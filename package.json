{
  "name": "markdown-reader",
  "version": "1.0.0",
  "description": "Read and preview .md files — Android (APK) + macOS (DMG)",
  "main": "electron/main.js",
  "author": "Marian",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dmg": "electron-builder --mac dmg",
    "cap:sync": "cap sync android",
    "apk": "cap sync android && cd android && ./gradlew assembleDebug"
  },
  "devDependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/cli": "^6.2.1",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "@capacitor/core": "^6.2.1",
    "katex": "^0.16.11",
    "mermaid": "^11.4.1"
  },
  "build": {
    "appId": "com.marian.markdownreader",
    "productName": "Markdown Reader",
    "directories": {
      "output": "dist-mac"
    },
    "files": [
      "electron/**/*",
      "www/**/*"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity"
    }
  }
}
